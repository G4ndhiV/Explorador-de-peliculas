# Copia este archivo a `.env` y rellena los valores (no subas `.env` a git).

# TMDB — https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=

# Opcional: idioma de la API (por defecto es-ES en código si no se define)
# VITE_TMDB_LANGUAGE=es-ES

# Firebase — Consola del proyecto → Configuración del proyecto → Tus apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
